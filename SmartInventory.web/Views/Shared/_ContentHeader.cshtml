@{
    var headerTitle = ViewData["HeaderTitle"] as string ?? "Dashboard";
    var breadcrumbFirst = ViewData["BreadcrumbFirst"] as string ?? "Home";
    var breadcrumbActive = ViewData["BreadcrumbActive"] as string ?? "Dashboard v1";
} 


<div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0 text-dark">@headerTitle</h1>
          </div><!-- /.col -->
          <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
              <li class="breadcrumb-item"><a href="#">@breadcrumbFirst</a></li>
              <li class="breadcrumb-item active">@breadcrumbActive</li>
            </ol>
          </div><!-- /.col -->
        </div><!-- /.row -->
      </div><!-- /.container-fluid -->
