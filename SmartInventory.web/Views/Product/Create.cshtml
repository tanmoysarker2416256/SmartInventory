@model SmartInventory.Contrct.Request.CreateProductRequest

@{
    ViewData["Title"] = "Create Product";
    ViewData["HeaderTitle"] = "Create Product";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Product";
}

<div class="row">
    <div class="col">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title">Create Product</h3>
            </div>

            <!-- Handled architectural post action cleanly -->
            <form class="form-horizontal" asp-action="Create" method="post">
                <div class="card-body">
                    <!-- Displays database duplicate name errors passed via ModelState safely -->
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group row">
                        <label asp-for="Name" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Name" type="text" class="form-control" placeholder="Name">
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label asp-for="Description" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Description" type="text" class="form-control" placeholder="Description">
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label asp-for="Price" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <!-- step="0.01" forces browser engine to support floating decimal entries like 24.99 natively -->
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Price">
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label asp-for="StockQuantity" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="StockQuantity" type="number" class="form-control" placeholder="Stock Quantity">
                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-info">Create</button>
                    <!-- Fixed: Safe routing redirection link that won't execute ghost form postings -->
                    <a asp-action="Index" class="btn btn-default float-right">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left mr-1"></i> Back to List</a>
</div>

@section Scripts {
    <!-- 
      Loads jquery.validate.js and jquery.validate.unobtrusive.js inside the Layout script bucket.
      This handles instant, client-side validation rules before it even hits your controller!
    -->
    <partial name="_ValidationScriptsPartial" />
}
